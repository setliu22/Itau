{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/visual-perturbation-record.schema.json",
  "title": "Visual Perturbation Dataset Record",
  "type": "object",
  "required": ["record_id", "record_type", "split", "source", "input", "target"],
  "properties": {
    "record_id": {
      "type": "string"
    },
    "record_type": {
      "type": "string",
      "enum": ["restoration", "legibility_pair", "legibility_candidate"]
    },
    "split": {
      "type": "string",
      "enum": ["train", "validation", "test"]
    },
    "source": {
      "type": "object",
      "required": ["dataset", "source_id", "unit", "paper_url", "repository_url"],
      "properties": {
        "dataset": {"type": "string"},
        "source_id": {"type": "string"},
        "unit": {"type": "string", "enum": ["word", "sentence"]},
        "paper_url": {"type": "string"},
        "repository_url": {"type": "string"}
      },
      "additionalProperties": true
    },
    "input": {
      "type": "object",
      "additionalProperties": true
    },
    "target": {
      "type": "object",
      "additionalProperties": true
    },
    "annotations": {
      "type": "object",
      "additionalProperties": true
    },
    "perturbation": {
      "type": "object",
      "additionalProperties": true
    },
    "features": {
      "type": "object",
      "properties": {
        "input_char_length": {"type": "integer"},
        "target_char_length": {"type": "integer"},
        "changed_char_count": {"type": "integer"},
        "changed_char_ratio": {"type": "number"},
        "non_ascii_count": {"type": "integer"},
        "non_ascii_ratio": {"type": "number"},
        "unicode_category_counts": {
          "type": "object",
          "additionalProperties": {"type": "integer"}
        }
      },
      "additionalProperties": true
    },
    "risk_tags": {
      "type": "array",
      "items": {"type": "string"}
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {"record_type": {"const": "restoration"}}
      },
      "then": {
        "properties": {
          "input": {
            "type": "object",
            "required": ["perturbed_text"],
            "properties": {
              "perturbed_text": {"type": "string"}
            }
          },
          "target": {
            "type": "object",
            "required": ["clean_text"],
            "properties": {
              "clean_text": {"type": "string"}
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {"record_type": {"const": "legibility_pair"}}
      },
      "then": {
        "properties": {
          "input": {
            "type": "object",
            "required": ["clean_text", "candidate_0", "candidate_1"],
            "properties": {
              "clean_text": {"type": "string"},
              "candidate_0": {"type": "string"},
              "candidate_1": {"type": "string"}
            }
          },
          "target": {
            "type": "object",
            "required": ["choice", "choice_label"],
            "properties": {
              "choice": {"type": "integer", "minimum": 0, "maximum": 3},
              "choice_label": {"type": "string"}
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {"record_type": {"const": "legibility_candidate"}}
      },
      "then": {
        "properties": {
          "input": {
            "type": "object",
            "required": ["clean_text", "perturbed_text"],
            "properties": {
              "clean_text": {"type": "string"},
              "perturbed_text": {"type": "string"}
            }
          },
          "target": {
            "type": "object",
            "required": ["clean_text"],
            "properties": {
              "clean_text": {"type": "string"},
              "legible": {
                "type": ["boolean", "null"]
              }
            }
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
