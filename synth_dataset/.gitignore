# Local caches and Python bytecode
.cache/
__pycache__/
**/__pycache__/
*.pyc

# Slurm/runtime logs
logs/
outputs/slurm/
*.out
*.err

# Generated datasets/results that are too large for git.
large_dataset/
large_dataset_q25/
NEW_RESULTS/
NEW_RESULTS_Q25/
validation_generation_q25/
validation_optuna_study/
generate_validation/runs/

# Protected local dataset folders. Keep README guards, never commit data files.
BASE_DATASETS_DO_NOT_EVER_DELETE/*
!BASE_DATASETS_DO_NOT_EVER_DELETE/README.md
NEW_DATASETS_DO_NOT_EVER_DELETE/*
!NEW_DATASETS_DO_NOT_EVER_DELETE/README.md
LOOKUP_TABLE_DO_NOT_DELETE_FOR_NOW/*
!LOOKUP_TABLE_DO_NOT_DELETE_FOR_NOW/README.md

# Model/checkpoint artifacts.
*.pt
*.pkl
*.png
*.parquet

# Duplicate tabular exports; parquet/text outputs are canonical here.
datasets/*.csv

# Debug/intermediate candidate-generation outputs.
outputs/replacement_candidates/*.parquet
outputs/replacement_candidates/*.json

# Rebuildable legacy OCR scratch artifacts.
datasets/dejavu_sans_trocr.hdf
datasets/dejavu_trocr_white_on_black_confusion_atlas.parquet
datasets/dejavu_trocr_white_on_black_confusion_atlas.manifest.json
